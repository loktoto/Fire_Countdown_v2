    "prettier": "^3.9.3",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "validate:web": "expo export --platform web --output-dir .codex/web-export --clear",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "\\\\node_modules\\\\",
      "\\\\_backups\\\\"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/_backups"
    ]
  },
  "private": true
